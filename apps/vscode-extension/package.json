{
  "name": "apiark-vscode",
  "displayName": "ApiArk",
  "description": "ApiArk integration for VS Code — browse collections, send requests, and run tests",
  "version": "0.2.1",
  "publisher": "apiark",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Testing", "Other"],
  "keywords": ["api", "rest", "http", "graphql", "grpc", "testing"],
  "activationEvents": [
    "workspaceContains:**/.apiark/apiark.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apiark.openCollection",
        "title": "ApiArk: Open Collection"
      },
      {
        "command": "apiark.sendRequest",
        "title": "ApiArk: Send Request"
      },
      {
        "command": "apiark.runCollection",
        "title": "ApiArk: Run Collection Tests"
      },
      {
        "command": "apiark.openInApp",
        "title": "ApiArk: Open in Desktop App"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "apiark.sendRequest",
          "when": "resourceExtname == .yaml && resourcePath =~ /.*(?<!\\.apiark).*\\.yaml$/",
          "group": "apiark"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "apiarkCollections",
          "name": "ApiArk Collections",
          "when": "apiark.hasCollections"
        }
      ]
    },
    "languages": [
      {
        "id": "apiark-yaml",
        "aliases": ["ApiArk Request"],
        "filenamePatterns": ["*.yaml"],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
